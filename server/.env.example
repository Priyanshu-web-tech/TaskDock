# Server
PORT=3001
NODE_ENV=development

# Security
COOKIE_SECRET=your-cookie-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
SERVER_REDIRECT_URI=http://localhost:3001

# JWT
SECRET_KEY=your-secret-key
JWT_ALGO=RS256
JWT_ISSUER=TASKDOCK
TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d

# OTP
OTP_DIGIT=6
OTP_EXPIRES_IN=15m
OTP_BYPASS=true
OTP=999666

# Database (PostgreSQL)
DB_HOST=localhost
DB_DATABASE=task-dock
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_SSL=false
DB_DIALECT=postgres
DB_POOL_MAX=30
DB_POOL_MIN=0
DB_ACQUIRE=1000000
DB_IDLE=200000

# Email (Brevo)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=sender@example.com

# Bcrypt
SALT_ROUND=10
